    replacement_chunks {
      replacement_content: "import React, { useState } from \'react\';\nimport { UserProgress } from \'../types\';\nimport { Star, Award, Sparkles, Printer, RotateCcw, Heart, Share2 } from \'lucide-react\';\nimport { playPop, playTrophy } from \'../utils/audio\';\n\ninterface CertificateProps {\n  progress: UserProgress;\n  onResetProgress: () => void;\n  onClose: () => void;\n}\n\ntype FrameStyle = \'gold\' | \'rainbow\' | \'forest\' | \'cosmic\';\n\nexport default function Certificate({ progress, onResetProgress, onClose }: CertificateProps) {\n  const [frame, setFrame] = useState<FrameStyle>(\'gold\');\n  const [showConfetti, setShowConfetti] = useState(false);\n\n  const getFrameClasses = () => {\n    switch (frame) {\n      case \'rainbow\':\n        return \'border-[16px] border-sky-300 bg-gradient-to-b from-sky-50 via-white to-pink-50 shadow-pink-200/50\';\n      case \'forest\':\n        return \'border-[16px] border-emerald-400 bg-gradient-to-b from-emerald-50 via-white to-amber-50 shadow-emerald-200/50\';\n      case \'cosmic\':\n        return \'border-[16px] border-purple-400 bg-gradient-to-b from-purple-50 via-white to-indigo-50 shadow-purple-200/50\';\n      case \'gold\':\n      default:\n        return \'border-[16px] border-yellow-400 bg-gradient-to-b from-amber-50 via-white to-yellow-50 shadow-yellow-200/50\';\n    }\n  };\n\n  const getFrameHeaderEmoji = () => {\n    switch (frame) {\n      case \'rainbow\': return \'\360\237\214\210\360\237\246\204\342\234\250\';\n      case \'forest\': return \'\360\237\214\262\360\237\246\211\360\237\246\212\';\n      case \'cosmic\': return \'\360\237\232\200\342\255\220\357\270\217\360\237\252\220\';\n      case \'gold\':\n      default: return \'\360\237\221\221\360\237\217\206\360\237\221\221\';\n    }\n  };\n\n  const handlePrint = () => {\n    playPop();\n    window.print();\n  };\n\n  const handleCelebrate = () => {\n    playTrophy();\n    setShowConfetti(true);\n    setTimeout(() => setShowConfetti(false), 3000);\n  };\n\n  return (\n    <div className=\"max-w-2xl mx-auto p-4 sm:p-6 bg-slate-50 rounded-3xl border border-slate-200 shadow-xl relative\">\n      \n      {/* Printable Area */}\n      <div id=\"urkunde-print-area\" className={`p-6 sm:p-10 rounded-2xl border-double text-center relative shadow-high-tactile transition-all duration-300 ${getFrameClasses()}`}>\n        \n        {/* Floating Sparkly items */}\n        <div className=\"absolute top-4 left-4 text-3xl animate-bounce\">\342\234\250</div>\n        <div className=\"absolute top-4 right-4 text-3xl animate-bounce\" style={{ animationDelay: \'0.5s\' }}>\342\255\220</div>\n        <div className=\"absolute bottom-4 left-4 text-3xl animate-bounce\" style={{ animationDelay: \'1s\' }}>\360\237\216\250</div>\n        <div className=\"absolute bottom-4 right-4 text-3xl animate-bounce\" style={{ animationDelay: \'0.8s\' }}>\360\237\216\210</div>\n\n        <div className=\"mb-4\">\n          <span className=\"text-3.5xl sm:text-5xl filter drop-shadow select-none block leading-none\">\n            {getFrameHeaderEmoji()}\n          </span>\n        </div>\n\n        <span className=\"font-sans font-black text-xs sm:text-sm uppercase tracking-widest text-[#00639a] bg-blue-100/60 px-4 py-1 rounded-full border border-blue-200 inline-block mb-3\">\n          Offizielle Auszeichnung\n        </span>\n\n        <h1 className=\"text-3xl sm:text-5xl font-sans font-black tracking-tight text-slate-800 leading-none\">\n          LERNK\303\226NIG URKUNDE\n        </h1>\n\n        <div className=\"w-24 h-1 bg-gradient-to-r from-transparent via-yellow-400 to-transparent mx-auto my-4 sm:my-5\"></div>\n\n        <p className=\"text-sm sm:text-base font-semibold text-slate-500 font-body block mb-2\">\n          Mit Stolz und Freude wird verliehen an:\n        </p>\n\n        {/* Child Personalization Name Box */}\n        <div className=\"bg-white/80 border-2 border-slate-200 inline-block px-8 py-3.5 rounded-2xl shadow-inner mb-5\">\n          <h2 className=\"text-2xl sm:text-3xl font-black text-amber-900 uppercase tracking-wide font-sans\">\n            {progress.childName || \"Mucki der schlaue Lerner\"}\n          </h2>\n        </div>\n\n        <p className=\"text-base sm:text-lg font-bold text-slate-700 leading-relaxed font-body max-w-md mx-auto mb-6\">\n          f\303\274r den herausragenden Erfolg in der <strong className=\"text-[#00639a]\">Lernwelt</strong>.<br />\n          Du hast alle kniffligen Aufgaben der Klassenstufen 1 bis 4 mit Bravour und viel Flei\303\237 gemeistert!\n        </p>\n\n        {/* Scores & Trophy Grid */}\n        <div className=\"grid grid-cols-2 gap-4 max-w-sm mx-auto mb-8\">\n          <div className=\"bg-white p-3 rounded-xl border border-dashed border-slate-300 text-center\">\n            <span className=\"text-sm font-bold text-slate-400 uppercase tracking-widest block font-sans\">Sterne gesammelt</span>\n            <span className=\"text-2xl sm:text-3xl font-black text-amber-500 flex items-center justify-center gap-1.5 mt-0.5\">\n              <Star className=\"w-6 h-6 fill-amber-400 text-amber-500\" /> {progress.starsCount}\n            </span>\n          </div>\n\n          <div className=\"bg-white p-3 rounded-xl border border-dashed border-slate-300 text-center\">\n            <span className=\"text-sm font-bold text-slate-400 uppercase tracking-widest block font-sans\">Rang</span>\n            <span className=\"text-lg sm:text-2xl font-black text-emerald-700 uppercase tracking-widest mt-0.5 block\">\n              Super-Sch\303\274ler \360\237\221\221\n            </span>\n          </div>\n        </div>\n\n        {/* Cute Signature Stamp mockup */}\n        <div className=\"flex justify-between items-end px-4 sm:px-10\">\n          <div className=\"text-left\">\n            <div className=\"w-28 sm:w-32 border-b-2 border-slate-400 h-8\"></div>\n            <span className=\"text-[10px] sm:text-xs font-bold text-slate-400 font-body\">Datum & Unterschrift</span>\n          </div>\n\n          <div className=\"relative\">\n            {/* Round Golden Stamp Vector SVG */}\n            <svg className=\"w-16 h-16 sm:w-20 sm:h-20\" viewBox=\"0 0 100 100\">\n              <circle cx=\"50\" cy=\"50\" r=\"42\" fill=\"#ffd54f\" stroke=\"#ffb300\" strokeWidth=\"3\" />\n              <circle cx=\"50\" cy=\"50\" r=\"36\" fill=\"none\" stroke=\"#ffb300\" strokeWidth=\"1\" strokeDasharray=\"4 2\" />\n              <path d=\"M50,22 L53,32 L63,32 L55,38 L58,48 L50,42 L42,48 L45,38 L37,32 L47,32 Z\" fill=\"#ff8f00\" />\n              <text x=\"50\" y=\"65\" textAnchor=\"middle\" fill=\"#ff8f00\" fontSize=\"10\" fontWeight=\"900\" fontFamily=\"sans-serif\">LERNWELT</text>\n              <text x=\"50\" y=\"76\" textAnchor=\"middle\" fill=\"#ff8f00\" fontSize=\"7\" fontWeight=\"bold\" fontFamily=\"sans-serif\">PROFI 2026</text>\n            </svg>\n          </div>\n        </div>\n      </div>\n\n      {/* Frame style customizer options */}\n      <div className=\"mt-8 bg-white p-4 rounded-2xl border border-slate-200\">\n        <h3 className=\"text-center text-xs font-bold uppercase tracking-wider text-slate-400 mb-3 font-sans\">\n          W\303\244hle dein Lieblings-Rahmendesign:\n        </h3>\n        \n        <div className=\"grid grid-cols-4 gap-2 mb-4\">\n          <button\n            onClick={() => { playPop(); setFrame(\'gold\'); }}\n            className={`px-2 py-2.5 rounded-xl border-2 text-xs font-bold text-yellow-800 transition-all cursor-pointer ${\n              frame === \'gold\' ? \'bg-yellow-100 border-yellow-400 scale-102 ring-2 ring-yellow-200\' : \'bg-slate-50 border-slate-200\'\n            }`}\n          >\n            \360\237\245\207 Goldk\303\266nig\n          </button>\n          \n          <button\n            onClick={() => { playPop(); setFrame(\'rainbow\'); }}\n            className={`px-2 py-2.5 rounded-xl border-2 text-xs font-bold text-pink-700 transition-all cursor-pointer ${\n              frame === \'rainbow\' ? \'bg-pink-100 border-sky-400 scale-102 ring-2 ring-pink-200\' : \'bg-slate-50 border-slate-200\'\n            }`}\n          >\n            \360\237\214\210 Regenbogen\n          </button>\n\n          <button\n            onClick={() => { playPop(); setFrame(\'forest\'); }}\n            className={`px-2 py-2.5 rounded-xl border-2 text-xs font-bold text-emerald-800 transition-all cursor-pointer ${\n              frame === \'forest\' ? \'bg-emerald-100 border-emerald-400 scale-102 ring-2 ring-emerald-200\' : \'bg-slate-50 border-slate-200\'\n            }`}\n          >\n            \360\237\214\262 Abenteuer\n          </button>\n\n          <button\n            onClick={() => { playPop(); setFrame(\'cosmic\'); }}\n            className={`px-2 py-2.5 rounded-xl border-2 text-xs font-bold text-purple-800 transition-all cursor-pointer ${\n              frame === \'cosmic\' ? \'bg-purple-100 border-purple-400 scale-102 ring-2 ring-purple-200\' : \'bg-slate-50 border-slate-200\'\n            }`}\n          >\n            \360\237\232\200 Weltraum\n          </button>\n        </div>\n\n        {/* Certificate Actions */}\n        <div className=\"flex flex-wrap items-center justify-center gap-3\">\n          <button\n            onClick={handleCelebrate}\n            className=\"btn-tactile-secondary text-amber-950 px-5 py-2.5 rounded-xl text-xs sm:text-sm font-extrabold flex items-center gap-2 cursor-pointer\"\n          >\n            <Sparkles className=\"w-4 h-4\" /> Lumi-Jubel anfeuern! \360\237\216\211\n          </button>\n\n          <button\n            onClick={handlePrint}\n            className=\"btn-tactile-primary text-white px-5 py-2.5 rounded-xl text-xs sm:text-sm font-extrabold flex items-center gap-2 cursor-pointer\"\n          >\n            <Printer className=\"w-4 h-4\" /> Urkunde drucken \360\237\226\250\357\270\217\n          </button>\n\n          <button\n            onClick={onClose}\n            className=\"btn-tactile-outline text-slate-700 px-5 py-2.5 rounded-xl text-xs sm:text-sm font-bold cursor-pointer\"\n          >\n            Zur\303\274ck zur Landkarte\n          </button>\n\n          <button\n            onClick={() => {\n              if (confirm(\"M\303\266chtest du dein Abenteuer wirklich zur\303\274cksetzen und von vorn beginnen?\")) {\n                playPop();\n                onResetProgress();\n              }\n            }}\n            className=\"text-red-500 hover:text-red-700 hover:bg-red-50 text-[10px] font-bold px-2 py-1 rounded-lg transition-colors cursor-pointer\"\n          >\n            Fortschritt l\303\266schen\n          </button>\n        </div>\n      </div>\n\n      {showConfetti && (\n        <div className=\"absolute inset-0 bg-yellow-500/10 rounded-3xl overflow-hidden pointer-events-none flex items-center justify-center\">\n          <div className=\"text-3xl text-center select-none animate-ping\">\n            \360\237\216\212 \360\237\216\210 \342\234\250 \360\237\221\221 \342\255\220 \360\237\245\263 \342\255\220\357\270\217 \360\237\216\210 \360\237\216\212\n          </div>\n        </div>\n      )}\n    </div>\n  );\n}\n"
    }
