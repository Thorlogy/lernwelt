    replacement_chunks {
      replacement_content: "@import url(\'https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@700;800&family=Quicksand:wght@500;700&display=swap\');\n@import \"tailwindcss\";\n\n@theme {\n  --font-sans: \"Plus Jakarta Sans\", ui-sans-serif, system-ui, sans-serif;\n  --font-body: \"Quicksand\", sans-serif;\n\n  /* Custom Color Palette reflecting the German School Brand Spec */\n  --color-brand-bg: #f7f9fc;\n  --color-brand-surface-lowest: #ffffff;\n  --color-brand-surface-low: #f2f4f7;\n  --color-brand-surface: #eceef1;\n  --color-brand-surface-high: #e6e8eb;\n  --color-brand-surface-highest: #e0e3e6;\n  \n  --color-brand-primary: #00639a;\n  --color-brand-primary-hover: #004e7a;\n  --color-brand-primary-container: #5ca9e9;\n  --color-brand-on-primary-container: #003c60;\n\n  --color-brand-secondary: #725c00;\n  --color-brand-secondary-container: #fdd758;\n  --color-brand-on-secondary-container: #ffd000;\n\n  --color-brand-tertiary: #286c2d;\n  --color-brand-tertiary-container: #abf4a5;\n  --color-brand-on-tertiary-container: #002204;\n\n  --color-brand-error: #ba1a1a;\n  --color-brand-error-container: #ffdad6;\n  --color-brand-orange: #e06000;\n  --color-brand-orange-container: #ffdcc8;\n\n  --color-on-surface: #191c1e;\n  --color-on-surface-variant: #404750;\n  --color-outline: #707881;\n  --color-outline-variant: #c0c7d1;\n}\n\n/* Custom styling rules for the Soft Tactile theme */\nbody {\n  font-family: var(--font-body);\n  background-color: var(--color-brand-bg);\n  color: var(--color-on-surface);\n  user-select: none;\n  -webkit-user-select: none;\n}\n\n/* Custom shadow with low opacity primary color for physical soft appearance */\n.shadow-soft-tactile {\n  box-shadow: 0 12px 24px -6px rgba(0, 99, 154, 0.08), \n              0 0 1px 0 rgba(0, 99, 154, 0.1);\n}\n\n.shadow-high-tactile {\n  box-shadow: 0 16px 32px -4px rgba(0, 99, 154, 0.12), \n              0 4px 8px -2px rgba(0, 99, 154, 0.05);\n}\n\n/* Chunky Tactile Buttons and Blocks */\n.btn-tactile-primary {\n  transition: all 0.15s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n  border-bottom: 5px solid #004a75;\n  background-color: #00639a;\n}\n.btn-tactile-primary:active {\n  transform: translateY(3px);\n  border-bottom: 2px solid #004a75;\n}\n\n.btn-tactile-secondary {\n  transition: all 0.15s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n  border-bottom: 5px solid #b28a00;\n  background-color: #fdd758;\n}\n.btn-tactile-secondary:active {\n  transform: translateY(3px);\n  border-bottom: 2px solid #b28a00;\n}\n\n.btn-tactile-tertiary {\n  transition: all 0.15s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n  border-bottom: 5px solid #144b1c;\n  background-color: #6db36b;\n}\n.btn-tactile-tertiary:active {\n  transform: translateY(3px);\n  border-bottom: 2px solid #144b1c;\n}\n\n.btn-tactile-outline {\n  transition: all 0.15s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n  border-bottom: 4px solid var(--color-brand-surface-high);\n  background-color: var(--color-brand-surface-lowest);\n}\n.btn-tactile-outline:active {\n  transform: translateY(2px);\n  border-bottom: 2px solid var(--color-brand-surface-high);\n}\n\n/* Tactile Letter Blocks */\n.letter-block {\n  font-family: var(--font-body);\n  font-weight: 700;\n  box-shadow: 0 4px 0 0 rgba(0, 99, 154, 0.15);\n  border: 2px solid var(--color-brand-surface-highest);\n  transition: all 0.1s ease;\n}\n\n.letter-block:active {\n  transform: translateY(2px);\n  box-shadow: 0 1px 0 0 rgba(0, 99, 154, 0.15);\n}\n\n/* Wiggle animations for mascot and feedback */\n@keyframes soft-wiggle {\n  0%, 100% { transform: rotate(0deg); }\n  25% { transform: rotate(-3deg); }\n  75% { transform: rotate(3deg); }\n}\n\n@keyframes double-wiggle {\n  0%, 100% { transform: translateY(0) rotate(0deg); }\n  20% { transform: translateY(-3px) rotate(-4deg); }\n  45% { transform: translateY(-1px) rotate(3deg); }\n  65% { transform: translateY(-3px) rotate(-2deg); }\n  80% { transform: translateY(0) rotate(1deg); }\n}\n\n@keyframes error-shake {\n  0%, 100% { transform: translateX(0); }\n  15%, 45%, 75% { transform: translateX(-6px); }\n  30%, 60%, 90% { transform: translateX(6px); }\n}\n\n.animate-wiggle-soft {\n  animation: soft-wiggle 3s ease-in-out infinite;\n}\n\n.animate-wiggle-double {\n  animation: double-wiggle 1.2s ease-in-out;\n}\n\n.animate-shake {\n  animation: error-shake 0.4s ease-in-out;\n}\n\n/* Hide scrollbar but keep functionality */\n.no-scrollbar::-webkit-scrollbar {\n  display: none;\n}\n.no-scrollbar {\n  -ms-overflow-style: none;\n  scrollbar-width: none;\n}\n"
    }
