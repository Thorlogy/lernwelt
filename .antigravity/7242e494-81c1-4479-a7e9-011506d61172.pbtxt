      replacement_content: "import { Station } from \'./types\';\n\nexport const STATIONEN: Station[] = [\n  {\n    id: 1,\n    title: \"Station 1: Buchstabensalat\",\n    subtitle: \"Erstleser & Wortbau\",\n    grade: 1,\n    description: \"Bringe die durcheinandergew\303\274rfelten Buchstaben in die richtige Reihenfolge, um das gesuchte Wort zu schreiben!\",\n    icon: \"Keyboard\",\n    color: \"primary\",\n    exercises: [\n      {\n        id: \"1_1\",\n        question: \"Bilde das Wort f\303\274r dieses s\303\274\303\237e Haustier:\",\n        word: \"KATZE\",\n        hint: \"Es macht \'Miau\' und f\303\244ngt gerne M\303\244use.\",\n        correctAnswer: \"KATZE\",\n        imagePlaceholder: \"cat\"\n      },\n      {\n        id: \"1_2\",\n        question: \"Schreibe dieses rote, knackige Obst:\",\n        word: \"APFEL\",\n        hint: \"Es w\303\244chst auf B\303\244umen und ist sehr gesund.\",\n        correctAnswer: \"APFEL\",\n        imagePlaceholder: \"apple\"\n      },\n      {\n        id: \"1_3\",\n        question: \"Wie hei\303\237t dieses kleine Tier, das K\303\244se liebt?\",\n        word: \"MAUS\",\n        hint: \"Es macht \'Piep\' und l\303\244uft vor der Katze weg.\",\n        correctAnswer: \"MAUS\",\n        imagePlaceholder: \"mouse\"\n      },\n      {\n        id: \"1_4\",\n        question: \"Bilde das Wort f\303\274r das, was hell am Himmel scheint:\",\n        word: \"SONNE\",\n        hint: \"Sie w\303\244rmt uns im Sommer und leuchtet tags\303\274ber.\",\n        correctAnswer: \"SONNE\",\n        imagePlaceholder: \"sun\"\n      },\n      {\n        id: \"1_5\",\n        question: \"Wie nennt man diesen gro\303\237en Baum im Wald?\",\n        word: \"TANNE\",\n        hint: \"Sie bleibt auch im Winter gr\303\274n und wird als Weihnachtsbaum geschm\303\274ckt.\",\n        correctAnswer: \"TANNE\",\n        imagePlaceholder: \"fir\"\n      }\n    ]\n  },\n  {\n    id: 2,\n    title: \"Station 2: Silben-H\303\274pfen\",\n    subtitle: \"Silbentrennung & Rhythmus\",\n    grade: 2,\n    description: \"Klicke die Silben in der richtigen Reihenfolge an, um das ganze Wort flie\303\237end zusammenzusetzen!\",\n    icon: \"Music\",\n    color: \"secondary\",\n    exercises: [\n      {\n        id: \"2_1\",\n        question: \"Zerteile das Wort \'Wasser\' in seine Silben:\",\n        word: \"WASSER\",\n        hint: \"Was-ser: Klatschen hilft dir!\",\n        correctAnswer: [\"WAS\", \"SER\"],\n        imagePlaceholder: \"water\"\n      },\n      {\n        id: \"2_2\",\n        question: \"Klatsche das Wort \'Schule\':\",\n        word: \"SCHULE\",\n        hint: \"Schu-le. Zwei Silben!\",\n        correctAnswer: [\"SCHU\", \"LE\"],\n        imagePlaceholder: \"school\"\n      },\n      {\n        id: \"2_3\",\n        question: \"Finde die Silben f\303\274r diese sch\303\266ne Fr\303\274hlingsblume:\",\n        word: \"TULPE\",\n        hint: \"Tul-pe. Sie bl\303\274ht im Garten.\",\n        correctAnswer: [\"TUL\", \"PE\"],\n        imagePlaceholder: \"tulip\"\n      },\n      {\n        id: \"2_4\",\n        question: \"Baue das Wort f\303\274r das bunte Wunder am Himmel nach dem Regen:\",\n        word: \"REGENBOGEN\",\n        hint: \"Re-gen-bo-gen. Vier Silben!\",\n        correctAnswer: [\"RE\", \"GEN\", \"BO\", \"GEN\"],\n        imagePlaceholder: \"rainbow\"\n      },\n      {\n        id: \"2_5\",\n        question: \"Zerteile dieses saftige rote Sommer-Gem\303\274se:\",\n        word: \"TOMATE\",\n        hint: \"To-ma-te. Drei Klatscher!\",\n        correctAnswer: [\"TO\", \"MA\", \"TE\"],\n        imagePlaceholder: \"tomato\"\n      }\n    ]\n  },\n  {\n    id: 3,\n    title: \"Station 3: Wortarten-Sortierer\",\n    subtitle: \"Grammatik & Ordnung\",\n    grade: 3,\n    description: \"Sortiere die W\303\266rter in die richtigen Schatztruhen: Nomen (Namenw\303\266rter), Verben (Tuw\303\266rter) oder Adjektive (Wiew\303\266rter)!\",\n    icon: \"FolderGit\",\n    color: \"tertiary\",\n    exercises: [\n      {\n        id: \"3_1\",\n        question: \"Wohin geh\303\266rt das Wort: HUND\",\n        word: \"Hund\",\n        hint: \"Ein Tier, das man anfassen kann. Nomen schreibt man gro\303\237!\",\n        correctAnswer: \"NOMEN\"\n      },\n      {\n        id: \"3_2\",\n        question: \"Wohin geh\303\266rt das Wort: RENNEN\",\n        word: \"rennen\",\n        hint: \"Etwas, das man tut (eine Bewegung).\",\n        correctAnswer: \"VERB\"\n      },\n      {\n        id: \"3_3\",\n        question: \"Wohin geh\303\266rt das Wort: S\303\234SS\",\n        word: \"s\303\274ss\",\n        hint: \"Wie schmeckt der Apfel? Er beschreibt eine Eigenschaft.\",\n        correctAnswer: \"ADJEKTIV\"\n      },\n      {\n        id: \"3_4\",\n        question: \"Wohin geh\303\266rt das Wort: SCHREIBEN\",\n        word: \"schreiben\",\n        hint: \"Was tust du mit deinem Stift?\",\n        correctAnswer: \"VERB\"\n      },\n      {\n        id: \"3_5\",\n        question: \"Wohin geh\303\266rt das Wort: KLUG\",\n        word: \"klug\",\n        hint: \"Wie ist Lumi der Drache?\",\n        correctAnswer: \"ADJEKTIV\"\n      },\n      {\n        id: \"3_6\",\n        question: \"Wohin geh\303\266rt das Wort: HAUS\",\n        word: \"Haus\",\n        hint: \"Ein Geb\303\244ude, in dem man wohnt. Ein Gegenstand oder Ding.\",\n        correctAnswer: \"NOMEN\"\n      }\n    ]\n  },\n  {\n    id: 4,\n    title: \"Station 4: Rechtschreib-Detektiv\",\n    subtitle: \"Satzbau & Gro\303\237-/Kleinschreibung\",\n    grade: 4,\n    description: \"Finde die Rechtschreibfehler in den S\303\244tzen und tippe auf die falschen W\303\266rter, um sie richtig zu korrigieren!\",\n    icon: \"Search\",\n    color: \"orange\",\n    exercises: [\n      {\n        id: \"4_1\",\n        question: \"In diesem Satz hat sich ein kleiner Buchstabendreher eingeschlichen:\",\n        hint: \"Achte auf das Wort f\303\274r das Tier, das fliegt! Es wird mit V geschrieben.\",\n        correctAnswer: \"Vogel\",\n        word: \"Der kleine fogel singt ein sch\303\266nes Lied im Baum.\",\n        correctAnswerText: \"fogel\" // Target word that is wrong\n      },\n      {\n        id: \"4_2\",\n        question: \"Wo ist das vergessene gro\303\237e \'S\'?\",\n        hint: \"Wochentage sind Nomen und werden immer gro\303\237geschrieben!\",\n        correctAnswer: \"Samstag\",\n        word: \"Am samstag spielen wir im Park alle zusammen.\",\n        correctAnswerText: \"samstag\"\n      },\n      {\n        id: \"4_3\",\n        question: \"Ein Aussprachefehler! \'schp\' schreibt man im Deutschen anders:\",\n        hint: \"Wir sprechen \'schpielen\' aus, aber schreiben es nur mit \'sp\'.\",\n        correctAnswer: \"spielen\",\n        word: \"Viele Kinder schbielen gerne Verstecken.\",\n        correctAnswerText: \"schbielen\"\n      },\n      {\n        id: \"4_4\",\n        question: \"Wie schreibt man dieses Fortbewegungsmittel richtig?\",\n        hint: \"Auto wird mit \'Au\' geschrieben und ist ein Nomen (gro\303\237!).\",\n        correctAnswer: \"Auto\",\n        word: \"Das rote ohto f\303\244hrt um die geheimnisvolle Kurve.\",\n        correctAnswerText: \"ohto\"\n      }\n    ]\n  }\n];\n\nexport const CHARACTER_AVATARS = [\n  { id: \'dragon\', name: \'Lumi (Drache)\', emoji: \'\360\237\220\211\', color: \'bg-emerald-100 border-emerald-300 text-emerald-700\' },\n  { id: \'unicorn\', name: \'Sternchen (Einhorn)\', emoji: \'\360\237\246\204\', color: \'bg-pink-100 border-pink-300 text-pink-700\' },\n  { id: \'owl\', name: \'Olli (Eule)\', emoji: \'\360\237\246\211\', color: \'bg-amber-100 border-amber-300 text-amber-700\' },\n  { id: \'rocket\', name: \'Kosmo (Rakete)\', emoji: \'\360\237\232\200\', color: \'bg-blue-100 border-blue-300 text-blue-700\' },\n  { id: \'fox\', name: \'Foxy (Fuchs)\', emoji: \'\360\237\246\212\', color: \'bg-orange-100 border-orange-300 text-orange-700\' },\n  { id: \'frog\', name: \'Quaki (Frosch)\', emoji: \'\360\237\220\270\', color: \'bg-green-100 border-green-300 text-green-700\' },\n];\n"
